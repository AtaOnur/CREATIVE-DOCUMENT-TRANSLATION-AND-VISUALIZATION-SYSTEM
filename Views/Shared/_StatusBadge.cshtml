@*
    [TR] Bu dosya ne işe yarar: Belge durumu için renkli rozet — tablo ve kartlarda ortak kullanım.
    [TR] Model: pdf_bitirme.Models.DocumentStatus (enum)

    MODIFICATION NOTES (TR)
    - İkon + yüzde ilerleme ile değiştirilebilir.
    - Zorluk: Kolay.
*@
@model pdf_bitirme.Models.DocumentStatus
@{
    var (css, label) = Model switch
    {
        pdf_bitirme.Models.DocumentStatus.UPLOADED => ("bg-secondary", "Uploaded"),
        pdf_bitirme.Models.DocumentStatus.PROCESSING => ("bg-info text-dark", "Processing"),
        pdf_bitirme.Models.DocumentStatus.OCR_READY => ("bg-primary", "OCR Ready"),
        pdf_bitirme.Models.DocumentStatus.AI_READY => ("bg-warning text-dark", "AI Ready"),
        pdf_bitirme.Models.DocumentStatus.COMPLETED => ("bg-success", "Completed"),
        pdf_bitirme.Models.DocumentStatus.FAILED => ("bg-danger", "Failed"),
        _ => ("bg-light text-dark", Model.ToString()),
    };
}
<span class="badge rounded-pill @css">@label</span>
