@model pdf_bitirme.Models.ViewModels.SettingsViewModel
@{
    ViewData["Title"] = "Ayarlar";
}

@*
    [TR] Bu dosya ne ise yarar: Hesap bilgisi ve AI tercihlerinin duzenlendigi ayarlar sayfasi.
    [TR] Neden gerekli: Kullanici varsayilan model/stil/tema tercihlerini tek yerden yonetsin.
    [TR] Ilgili: SettingsController.Index/Update

    MODIFICATION NOTES (TR)
    - Cok dilli UI ve bildirim ayarlari ileride eklenebilir.
    - API key / advanced admin ayarlari ileride eklenebilir.
    - Genel resim OCR destegi bu surumde yer almamaktadir.
*@

<div class="app-page-header py-3 border-bottom border-light-subtle mb-3">
    <div class="container">
        <h1 class="h4 fw-bold text-app-primary mb-1">Ayarlar</h1>
        <p class="text-muted small mb-0">Hesap ve AI tercih ayarlari</p>
    </div>
</div>

<div class="container pb-4">
    <div class="row g-3">
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm settings-card h-100">
                <div class="card-body">
                    <h2 class="h6 fw-bold">Hesap Bilgisi</h2>
                    <div class="small text-muted mb-1">Kullanici Adi</div>
                    <div class="mb-3">@Model.Username</div>
                    <div class="small text-muted mb-1">Email</div>
                    <div>@Model.Email</div>
                    <hr />
                    <h3 class="h6 fw-bold">Guvenlik</h3>
                    <p class="small text-muted mb-2">Basit hesap guvenligi bolumu (MVP).</p>
                    <a class="btn btn-outline-secondary btn-sm" asp-controller="Account" asp-action="ForgotPassword">Parola Sifirla</a>
                </div>
            </div>
        </div>
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm settings-card">
                <div class="card-body">
                    <h2 class="h6 fw-bold mb-3">AI Tercihleri</h2>
                    <form asp-action="Update" method="post" data-loading-form="true">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Username" />
                        <input type="hidden" asp-for="Email" />

                        <div class="mb-3">
                            <label asp-for="DefaultAiModel" class="form-label">Varsayilan Model</label>
                            <select asp-for="DefaultAiModel" class="form-select">
                                @foreach (var m in Model.AvailableAiModels)
                                {
                                    if (string.Equals(Model.DefaultAiModel, m, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <option value="@m" selected>@m</option>
                                    }
                                    else
                                    {
                                        <option value="@m">@m</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="DefaultAiModel" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DefaultTranslationStyle" class="form-label">Varsayilan Ceviri Stili</label>
                            <select asp-for="DefaultTranslationStyle" class="form-select">
                                <option value="Formal">Formal</option>
                                <option value="Academic">Academic</option>
                                <option value="Simplified">Simplified</option>
                            </select>
                            <span asp-validation-for="DefaultTranslationStyle" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ThemePreference" class="form-label">Tema Tercihi (Placeholder)</label>
                            <select asp-for="ThemePreference" class="form-select">
                                <option value="System">System</option>
                                <option value="Light">Light</option>
                                <option value="Dark">Dark</option>
                            </select>
                            <span asp-validation-for="ThemePreference" class="text-danger small"></span>
                        </div>

                        <button class="btn btn-accent" type="submit">Ayarları Kaydet</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

