@*
    [TR] Bu dosya ne işe yarar: Giriş formu — e-posta, parola (göster/gizle), beni hatırla.
    [TR] İlgili: LoginViewModel, AccountController.Login (GET/POST)

    MODIFICATION NOTES (TR)
    - CAPTCHA veya hız sınırlama kötüye kullanıma karşı.
    - Sosyal giriş düğmeleri (isteğe bağlı OAuth).
    - Zorluk: Kolay–orta.
*@
@model pdf_bitirme.Models.LoginViewModel
@{
    ViewData["Title"] = "Giriş";
}

<div class="auth-page py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-5">
                <div class="card auth-card border-0">
                    <div class="card-body p-4 p-md-5">
                        <h1 class="h3 fw-bold text-app-primary mb-1">Giriş</h1>
                        <p class="text-muted small mb-4">CreativeDoc hesabınızla oturum açın.</p>

                        @* E-posta doğrulama başarı mesajı (query param ile gelir, TempData kullanılmaz) *@
                        @if (ViewBag.VerifiedMessage is string verifiedMsg && !string.IsNullOrWhiteSpace(verifiedMsg))
                        {
                            <div class="alert alert-success small">
                                ✓ @verifiedMsg
                            </div>
                        }

                        @* Demo doğrulama linki (mail gönderilemediğinde gösterilir) *@
                        @if (TempData["DemoVerifyLink"] is string verifyLink && !string.IsNullOrWhiteSpace(verifyLink))
                        {
                            <div class="alert alert-warning small">
                                <strong>Demo doğrulama linki:</strong>
                                <a href="@verifyLink" class="link-app">E-postami dogrula</a>
                            </div>
                        }

                        <form asp-controller="Account" asp-action="Login" method="post" novalidate data-loading-form="true">
                        @Html.AntiForgeryToken()
                            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                            <input type="hidden" asp-for="ReturnUrl" />

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label fw-medium"></label>
                                <input asp-for="Email" class="form-control form-control-lg border-app" autocomplete="username" placeholder="ornek@universite.edu" />
                                <span asp-validation-for="Email" class="text-danger small d-block"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="Password" class="form-label fw-medium"></label>
                                <div class="input-group">
                                    <input asp-for="Password" id="loginPassword" class="form-control form-control-lg border-app" autocomplete="current-password" />
                                    <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('loginPassword', this)" title="Göster/Gizle">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/><path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/></svg>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="text-danger small d-block"></span>
                            </div>
                            <div class="mb-4 form-check">
                                <input asp-for="RememberMe" class="form-check-input" />
                                <label asp-for="RememberMe" class="form-check-label small"></label>
                            </div>
                            <button type="submit" class="btn btn-accent btn-lg w-100 mb-3">Giriş Yap</button>
                        </form>

                        <div class="d-flex flex-column flex-sm-row justify-content-between gap-2 small">
                            <a asp-action="ForgotPassword" class="link-app">Şifremi unuttum</a>
                            <a asp-action="Register" class="link-app">Hesap oluştur</a>
                        </div>

                        <hr class="my-4 text-muted opacity-25" />
                        <p class="small text-muted mb-0">
                            <strong>Demo:</strong> <code>demo@university.edu</code> / <code>demo123</code>
                        </p>
                    </div>
                </div>
                <p class="text-center mt-3 small text-muted">
                    <a asp-controller="Home" asp-action="Index" class="link-secondary">← Ana sayfaya dön</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword(inputId, btn) {
            const input = document.getElementById(inputId);
            const isHidden = input.type === 'password';
            input.type = isHidden ? 'text' : 'password';
            btn.innerHTML = isHidden
                ? '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7.028 7.028 0 0 0-2.79.588l.77.771A5.944 5.944 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.134 13.134 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755-.165.165-.337.328-.517.486l.708.709z"/><path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829l.822.822zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829z"/><path d="M3.35 5.47c-.18.16-.353.322-.518.487A13.134 13.134 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7.029 7.029 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709z"/><path fill-rule="evenodd" d="M13.646 14.354l-12-12 .708-.708 12 12-.708.708z"/></svg>'
                : '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/><path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/></svg>';
        }
    </script>
}
