@*
    [TR] Bu dosya ne işe yarar: Kayıt formu — e-posta, güçlü parola zorunluluğu, göster/gizle butonu.
    [TR] İlgili: RegisterViewModel, AccountController.Register

    MODIFICATION NOTES (TR)
    - Kullanım koşulları onay kutusu eklenebilir.
    - Parola gücü göstergesi (strength bar) JS ile eklenebilir.
    - Zorluk: Kolay–orta.
*@
@model pdf_bitirme.Models.RegisterViewModel
@{
    ViewData["Title"] = "Kayıt Ol";
}

<div class="auth-page py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-5">
                <div class="card auth-card border-0">
                    <div class="card-body p-4 p-md-5">
                        <h1 class="h3 fw-bold text-app-primary mb-1">Kayıt Ol</h1>
                        <p class="text-muted small mb-4">Yeni hesap oluşturun; girişten önce e-posta doğrulaması gerekir.</p>

                        <form asp-controller="Account" asp-action="Register" method="post" novalidate data-loading-form="true">
                            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label fw-medium"></label>
                                <input asp-for="Email" class="form-control form-control-lg border-app" autocomplete="username" />
                                <span asp-validation-for="Email" class="text-danger small d-block"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label fw-medium"></label>
                                <div class="input-group">
                                    <input asp-for="Password" id="regPassword" class="form-control form-control-lg border-app" autocomplete="new-password" />
                                    <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('regPassword', this)" title="Göster/Gizle">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/><path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/></svg>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="text-danger small d-block"></span>
                                <div class="form-text">En az 8 karakter, bir büyük harf, bir rakam ve bir özel karakter (@@!#$%^&amp;* vb.).</div>
                            </div>

                            <div class="mb-4">
                                <label asp-for="ConfirmPassword" class="form-label fw-medium"></label>
                                <div class="input-group">
                                    <input asp-for="ConfirmPassword" id="regConfirm" class="form-control form-control-lg border-app" autocomplete="new-password" />
                                    <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('regConfirm', this)" title="Göster/Gizle">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/><path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/></svg>
                                    </button>
                                </div>
                                <span asp-validation-for="ConfirmPassword" class="text-danger small d-block"></span>
                            </div>

                            <button type="submit" class="btn btn-accent btn-lg w-100 mb-3">Kayıt Ol</button>
                        </form>

                        <p class="small text-muted mb-0 text-center">
                            Zaten hesabınız var mı?
                            <a asp-action="Login" class="link-app fw-medium">Giriş yapın</a>
                        </p>
                    </div>
                </div>
                <p class="text-center mt-3 small text-muted">
                    <a asp-controller="Home" asp-action="Index" class="link-secondary">← Ana sayfaya dön</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword(inputId, btn) {
            const input = document.getElementById(inputId);
            const isHidden = input.type === 'password';
            input.type = isHidden ? 'text' : 'password';
            btn.innerHTML = isHidden
                ? '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7.028 7.028 0 0 0-2.79.588l.77.771A5.944 5.944 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.134 13.134 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755-.165.165-.337.328-.517.486l.708.709z"/><path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829l.822.822zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829z"/><path d="M3.35 5.47c-.18.16-.353.322-.518.487A13.134 13.134 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7.029 7.029 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709z"/><path fill-rule="evenodd" d="M13.646 14.354l-12-12 .708-.708 12 12-.708.708z"/></svg>'
                : '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/><path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/></svg>';
        }
    </script>
}
