@*
    [TR] Bu dosya ne işe yarar: Şifre sıfırlama isteği — e-posta alanı ve demo bağlantı kutusu.
    [TR] İlgili: ForgotPasswordViewModel, AccountController.ForgotPassword

    MODIFICATION NOTES (TR)
    - SMTP ile tek kullanımlık link e-postası; TempData demo linki kaldırılır.
    - İstek sayısı sınırlaması.
    - Zorluk: Orta.
*@
@model pdf_bitirme.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Şifremi unuttum";
}

<div class="auth-page py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-5">
                <div class="card auth-card border-0">
                    <div class="card-body p-4 p-md-5">
                        <h1 class="h3 fw-bold text-app-primary mb-1">Şifremi unuttum</h1>
                        <p class="text-muted small mb-4">Kayıtlı e-postanızı girin. Üretim ortamında size sıfırlama bağlantısı gönderilir.</p>

                        @if (TempData["ForgotGenericMessage"] is string msg)
                        {
                            <div class="alert alert-info border-0 small mb-4" role="status">@msg</div>
                        }
                        @if (TempData["DemoResetLink"] is string demoLink)
                        {
                            <div class="alert alert-secondary border-0 small mb-4" role="note">
                                <strong>Demo ortamı:</strong> Aşağıdaki bağlantı e-posta yerine gösterilir.
                                <div class="mt-2 text-break"><a href="@demoLink" class="link-app">Şifreyi sıfırla</a></div>
                            </div>
                        }
                        @if (TempData["AuthError"] is string err)
                        {
                            <div class="alert alert-warning border-0 small mb-4" role="alert">@err</div>
                        }

                        <form asp-controller="Account" asp-action="ForgotPassword" method="post" novalidate data-loading-form="true">
                            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                            <div class="mb-4">
                                <label asp-for="Email" class="form-label fw-medium"></label>
                                <input asp-for="Email" class="form-control form-control-lg border-app" autocomplete="username" />
                                <span asp-validation-for="Email" class="text-danger small d-block"></span>
                            </div>
                            <button type="submit" class="btn btn-accent btn-lg w-100 mb-3">Sıfırlama bağlantısı iste</button>
                        </form>

                        <p class="small text-muted mb-0 text-center">
                            <a asp-action="Login" class="link-app">Girişe dön</a>
                        </p>
                    </div>
                </div>
                <p class="text-center mt-3 small text-muted">
                    <a asp-controller="Home" asp-action="Index" class="link-secondary">← Ana sayfaya dön</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
