@using pdf_bitirme.Models
@model pdf_bitirme.Models.ViewModels.AdminDocumentsViewModel
@{
    ViewData["Title"] = "Document Management";
}

@*
    [TR] Bu dosya ne işe yarar: Admin belge listesi, arama/filtre ve silme akışına geçiş ekranı.
    [TR] Neden gerekli: Problemli içerikleri hızlı tespit edip kaldırmak için temel moderasyon yüzü sağlar.
    [TR] İlgili: AdminController.Documents, AdminController.DeleteDocument

    MODIFICATION NOTES (TR)
    - Gelecekte rapor nedeni (uygunsuz içerik vb.) kolonları eklenebilir.
    - Banli belgeler listede rozetle gosterilir; admin PDF'i dogrudan acabilir.
    - Bulk delete veya toplu durum güncelleme eklenebilir.
    - Bu admin yapısı bitirme projesi kapsamında bilinçli olarak basit tutulmuştur; sonra genişletilebilir.
*@

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4 fw-bold mb-0">Document Management</h1>
        <a class="btn btn-outline-secondary" asp-action="Index">Admin Home</a>
    </div>

    <form method="get" class="card border-0 shadow-sm mb-3">
        <div class="card-body d-flex gap-2 flex-wrap">
            <input class="form-control" style="max-width:24rem" type="text" name="q" value="@Model.SearchQuery" placeholder="Search by document or user..." />
            <select class="form-select" style="max-width:14rem" name="status">
                <option value="">All Statuses</option>
                @foreach (var status in Enum.GetValues<DocumentStatus>())
                {
                    if (Model.StatusFilter == status.ToString())
                    {
                        <option value="@status" selected>@status</option>
                    }
                    else
                    {
                        <option value="@status">@status</option>
                    }
                }
            </select>
            <button class="btn btn-accent" type="submit">Filter</button>
            <a class="btn btn-outline-secondary" asp-action="Documents">Clear</a>
        </div>
    </form>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            @if (!Model.HasAny)
            {
                <p class="text-muted mb-0">No documents match the criteria.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                        <tr>
                            <th>Document Name</th>
                            <th>Owner</th>
                            <th>Upload Date</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var row in Model.Documents)
                        {
                            <tr>
                                <td>@row.DocumentName</td>
                                <td>@row.OwnerEmail</td>
                                <td>@row.UploadDateUtc.ToLocalTime().ToString("g")</td>
                                <td>
                                    <partial name="_StatusBadge" model="@row.Status" />
                                    @if (row.IsBanned)
                                    {
                                        <span class="badge text-bg-danger ms-1">Banned</span>
                                    }
                                </td>
                                <td>
                                    <a class="btn btn-sm btn-outline-primary me-1" asp-action="DocumentDetails" asp-route-id="@row.Id">Details</a>
                                    <a class="btn btn-sm btn-outline-secondary me-1" asp-action="Pdf" asp-route-id="@row.Id" target="_blank" rel="noopener">PDF</a>
                                    <form asp-action="DeleteDocument" method="post" class="d-inline" data-loading-form="true">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@row.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to delete this document?');">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

