@model pdf_bitirme.Models.ViewModels.AdminUsersViewModel
@{
    ViewData["Title"] = "User Management";
}

@*
    [TR] Bu dosya ne işe yarar: Admin kullanıcı listesi ve temel durum yönetimi giriş ekranı.
    [TR] Neden gerekli: Kullanıcı arama, rol/durum görme ve detay sayfasına geçiş için.
    [TR] İlgili: AdminController.Users

    MODIFICATION NOTES (TR)
    - Gelişmiş filtre (rol, aktiflik, kayıt tarihi) eklenebilir.
    - Sayfalama eklenerek büyük kullanıcı listeleri optimize edilebilir.
    - Bu admin yapısı bitirme projesi kapsamında bilinçli olarak basit tutulmuştur; sonra genişletilebilir.
*@

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4 fw-bold mb-0">User Management</h1>
        <a class="btn btn-outline-secondary" asp-action="Index">Admin Home</a>
    </div>

    <form method="get" class="card border-0 shadow-sm mb-3">
        <div class="card-body d-flex gap-2 flex-wrap">
            <input class="form-control" style="max-width:26rem" type="text" name="q" value="@Model.SearchQuery" placeholder="Search by email..." />
            <select class="form-select" style="max-width:12rem" name="status">
                @if (string.IsNullOrWhiteSpace(Model.StatusFilter))
                {
                    <option value="" selected>All Statuses</option>
                }
                else
                {
                    <option value="">All Statuses</option>
                }
                @if (Model.StatusFilter == "active")
                {
                    <option value="active" selected>Active</option>
                }
                else
                {
                    <option value="active">Active</option>
                }
                @if (Model.StatusFilter == "passive")
                {
                    <option value="passive" selected>Passive</option>
                }
                else
                {
                    <option value="passive">Passive</option>
                }
            </select>
            <button class="btn btn-accent" type="submit">Search</button>
            <a class="btn btn-outline-secondary" asp-action="Users">Clear</a>
        </div>
    </form>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            @if (!Model.HasAny)
            {
                <p class="text-muted mb-0">No users match the criteria.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                        <tr>
                            <th>Username</th>
                            <th>Verification</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Email</th>
                            <th>Registered</th>
                            <th>Action</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>@user.Username</td>
                                <td>@user.Email</td>
                                <td><span class="badge admin-badge @(user.Role == "Admin" ? "admin-badge-admin" : "admin-badge-neutral")">@user.Role</span></td>
                                <td><span class="badge admin-badge @(user.IsActive ? "admin-badge-success" : "admin-badge-warning")">@(user.IsActive ? "Active" : "Passive")</span></td>
                                <td><span class="badge admin-badge @(user.IsEmailVerified ? "admin-badge-success" : "admin-badge-neutral")">@(user.IsEmailVerified ? "Verified" : "Pending")</span></td>
                                <td>@user.CreatedAtUtc.ToLocalTime().ToString("g")</td>
                                <td>
                                    <a class="btn btn-sm btn-outline-primary" asp-action="UserDetails" asp-route-id="@user.Email">Details</a>
                                    <form asp-action="DeleteUser" method="post" class="d-inline" data-loading-form="true">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="email" value="@user.Email" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to delete this user?');">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

