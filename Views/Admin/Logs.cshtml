@model pdf_bitirme.Models.ViewModels.AdminLogsViewModel
@{
    ViewData["Title"] = "Logs and Usage Monitoring";
}

@*
    [TR] Bu dosya ne işe yarar: OCR/AI/upload/delete/login gibi temel kullanım loglarını listeler.
    [TR] Neden gerekli: Adminin sistemde neler olduğunu anlaşılır şekilde izlemesini sağlar.
    [TR] İlgili: AdminController.Logs, ActivityEntry

    MODIFICATION NOTES (TR)
    - Log detayları arttırılabilir (IP, endpoint, request-id).
    - CSV export veya zaman aralığı raporu eklenebilir.
    - Bu admin yapısı bitirme projesi kapsamında bilinçli olarak basit tutulmuştur; sonra genişletilebilir.
*@

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4 fw-bold mb-0">Usage Logs</h1>
        <a class="btn btn-outline-secondary" asp-action="Index">Admin Home</a>
    </div>

    <form method="get" class="card border-0 shadow-sm mb-3">
        <div class="card-body d-flex gap-2 flex-wrap align-items-center">
            <label class="small text-muted mb-0" for="actionType">Action Type:</label>
            <select id="actionType" class="form-select" style="max-width:14rem" name="actionType">
                <option value="">All Records</option>
                @foreach (var opt in new[] { "LOGIN", "LOGOUT", "UPLOAD", "OCR", "AI", "DELETE", "OTHER" })
                {
                    if (Model.ActionFilter == opt)
                    {
                        <option value="@opt" selected>@opt</option>
                    }
                    else
                    {
                        <option value="@opt">@opt</option>
                    }
                }
            </select>
            <button class="btn btn-accent" type="submit">Apply</button>
            <a class="btn btn-outline-secondary" asp-action="Logs">Clear</a>
        </div>
    </form>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            @if (!Model.HasAny)
            {
                <p class="text-muted mb-0">No log records to display.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                        <tr>
                            <th>Date</th>
                            <th>Action</th>
                            <th>User</th>
                            <th>Description</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var row in Model.Logs)
                        {
                            <tr>
                                <td>@row.DateUtc.ToLocalTime().ToString("g")</td>
                                <td><span class="badge admin-badge admin-badge-neutral">@row.ActionType</span></td>
                                <td>@row.UserEmail</td>
                                <td>@row.Description</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

