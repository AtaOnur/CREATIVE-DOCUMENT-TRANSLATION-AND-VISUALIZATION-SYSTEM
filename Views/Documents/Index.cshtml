@*
    [TR] Bu dosya ne işe yarar: Tüm PDF belgeleri — arama, durum filtresi, tablo, aç/sil.
    [TR] Model: DocumentsIndexViewModel
    [TR] İlgili: DocumentsController.Index

    MODIFICATION NOTES (TR)
    - Sunucu tarafı sayfalama (skip/take).
    - Kart görünümü mobilde alternatif düzen.
    - Zorluk: Kolay.
*@
@model pdf_bitirme.Models.ViewModels.DocumentsIndexViewModel
@{
    ViewData["Title"] = "Documents";
    var statuses = Enum.GetValues(typeof(pdf_bitirme.Models.DocumentStatus)).Cast<pdf_bitirme.Models.DocumentStatus>().ToList();
}

<div class="app-page-header py-4 border-bottom border-light-subtle mb-4">
    <div class="container d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div>
            <h1 class="h2 fw-bold text-app-primary mb-1">Documents</h1>
            <p class="text-muted mb-0 small">PDF only. OCR is scoped to selected PDF regions; general image OCR is future work.</p>
        </div>
        <a class="btn btn-accent btn-lg px-4" asp-action="Upload">Upload</a>
    </div>
</div>

<div class="container pb-5">
    <form method="get" class="card border-0 shadow-sm mb-4">
        <div class="card-body p-3">
            <div class="row g-2 align-items-end">
                <div class="col-md-5">
                    <label class="form-label small fw-medium mb-1" for="q">Search</label>
                    <input class="form-control border-app" id="q" name="q" value="@Model.SearchQuery" placeholder="Title or file name..." />
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-medium mb-1" for="status">Status</label>
                    <select class="form-select border-app" id="status" name="status">
                        <option value="">All</option>
                        @foreach (var s in statuses)
                        {
                            if (string.Equals(Model.StatusFilter, s.ToString(), StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@s" selected>@s</option>
                            }
                            else
                            {
                                <option value="@s">@s</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-accent flex-grow-1">Filter</button>
                    <a class="btn btn-outline-secondary" asp-action="Index">Reset</a>
                </div>
            </div>
        </div>
    </form>

    @if (!Model.HasAny)
    {
        <div class="card border-0 shadow-sm empty-state-card text-center py-5">
            <div class="display-6 text-muted mb-3">📭</div>
            <h2 class="h5 fw-bold">No documents found</h2>
            <p class="text-muted small mx-auto mb-3" style="max-width:26rem">Change the filters or upload a new PDF.</p>
            <a class="btn btn-accent" asp-action="Upload">Upload PDF</a>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>File</th>
                            <th>Size</th>
                            <th>Status</th>
                            <th>Updated</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.Documents)
                        {
                            <tr>
                                <td class="fw-medium">@d.Title</td>
                                <td class="small text-muted text-truncate" style="max-width:10rem">@d.FileName</td>
                                <td class="small">@FileSizeFormatter.Format(d.SizeBytes)</td>
                                <td><partial name="_StatusBadge" model="d.Status" /></td>
                                <td class="small text-muted">@d.UpdatedAtUtc.ToLocalTime().ToString("g")</td>
                                <td class="text-end text-nowrap">
                                    <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@d.Id">Open</a>
                                    <form asp-action="Delete" asp-route-id="@d.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this document?');" data-loading-form="true">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
