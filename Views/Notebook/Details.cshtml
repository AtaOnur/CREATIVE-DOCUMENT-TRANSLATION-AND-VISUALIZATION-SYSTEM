@model pdf_bitirme.Models.ViewModels.AiResultPageViewModel
@{
    ViewData["Title"] = "Notebook Details";
}

@*
    [TR] Bu dosya ne ise yarar: Kaydedilen notebook girdisinin detay gorunumu.
    [TR] Neden gerekli: Islem tipi/model/stil ve ciktiyi tek ekranda gostermek.
    [TR] Ilgili: NotebookController.Details

    MODIFICATION NOTES (TR)
    - Gelecekte onceki surumlerle karsilastirma alani eklenebilir.
    - Favori/etiket rozeti eklenebilir.
    - TTS kayitlari icin detayda audio player gosterilir.
    - Genel resim OCR destegi bu surumde yer almamaktadir.
*@

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4 fw-bold mb-0">Notebook Entry Details</h1>
        <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Back to Notebook</a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="row g-3 small">
                <div class="col-md-4"><strong>Operation:</strong> @Model.OperationType</div>
                <div class="col-md-4"><strong>Model:</strong> @Model.ModelName</div>
                <div class="col-md-4"><strong>Style:</strong> @Model.Style</div>
                <div class="col-md-6"><strong>Document:</strong> @Model.DocumentTitle</div>
                <div class="col-md-3"><strong>Source Page:</strong> @Model.SourcePageNumber</div>
                <div class="col-md-3"><strong>Save Status:</strong> @(Model.IsSaved ? "Saved" : "Temporary")</div>
                <div class="col-12"><strong>Instruction:</strong> @(string.IsNullOrWhiteSpace(Model.CustomInstruction) ? "-" : Model.CustomInstruction)</div>
            </div>
            <hr />
            <h2 class="h6 fw-bold">Output</h2>
            <div class="border rounded p-2 bg-light-subtle small mb-3" style="white-space: pre-wrap;">@Model.OutputText</div>
            @if (!string.IsNullOrWhiteSpace(Model.OutputImageUrl))
            {
                <img src="@Model.OutputImageUrl" alt="Notebook visual output" class="img-fluid rounded border mb-3" />
            }
            @if (!string.IsNullOrWhiteSpace(Model.OutputAudioUrl))
            {
                <div class="mb-3">
                    <h3 class="h6 fw-bold">Audio Recording</h3>
                    <audio controls class="w-100">
                        <source src="@Model.OutputAudioUrl" type="@Model.OutputAudioContentType" />
                        Your browser does not support the audio player.
                    </audio>
                </div>
            }
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-outline-primary btn-sm" asp-action="Edit" asp-route-id="@Model.AiResultId">Edit Note</a>
                <a class="btn btn-outline-secondary btn-sm" asp-controller="Documents" asp-action="Details" asp-route-id="@Model.DocumentId">Back to Document</a>
                <form asp-action="Delete" method="post" data-loading-form="true">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.AiResultId" />
                    <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

