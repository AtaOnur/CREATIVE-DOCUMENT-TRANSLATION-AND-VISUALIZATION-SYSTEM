# Microsoft SQL Server — Prisma
# Port: SSMS veya sqlcmd ile → SELECT port, ip_address FROM sys.dm_tcp_listener_states
# Bu repoda başarılı örnek: 127.0.0.1 + dinlenen port (çoğu kurulum 1433; bazıları 1434).

# Windows kimlik doğrulama (önerilen yerel geliştirme):
DATABASE_URL="sqlserver://127.0.0.1:1434;database=creative_doc_db;integratedSecurity=true;encrypt=true;trustServerCertificate=true"

# SQL girişi (sunucuda karma mod açık olmalı):
# DATABASE_URL="sqlserver://127.0.0.1:1434;database=creative_doc_db;user=APP_USER;password=YOUR_PASSWORD;encrypt=true;trustServerCertificate=true"

# Next.js (ileride)
# NEXTAUTH_URL=
# NEXTAUTH_SECRET=

# [TR] Bu dosya ne işe yarar: örnek ortam değişkenleri (.env için şablon).
# [TR] Sistem içinde: prisma db push, migrate, seed.

# MODIFICATION NOTES (TR)
# - Uzak sunucu / Azure SQL: firewall, TLS, connection string MS dokümantasyonuna göre.
# - Zorluk: kolay–orta.
